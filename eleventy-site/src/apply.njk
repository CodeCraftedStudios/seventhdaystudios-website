    let selectedRole = null;

    function selectRole(card) {
        document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        selectedRole = card.dataset.role;
        document.getElementById('field-role').value = selectedRole;

        document.querySelectorAll('[id^="questions-"]').forEach(el => el.classList.remove('visible'));
        const block = document.getElementById('questions-' + selectedRole);
        if (block) block.classList.add('visible');

        document.getElementById('role-prompt').style.display = 'none';
        document.getElementById('core-questions').classList.add('visible');
    }

    function initCharCounter(selector, counterId, max) {
        const ta = document.querySelector(selector);
        const counter = document.getElementById(counterId);
        if (!ta || !counter) return;
        ta.addEventListener('input', () => {
            const len = ta.value.length;
            counter.textContent = len + ' / ' + max;
            counter.classList.toggle('warning', len > max * 0.8);
        });
    }

    initCharCounter('[name="dev_project"]',         'cc-dev-project',       500);
    initCharCounter('[name="art_style"]',            'cc-art-style',         500);
    initCharCounter('[name="music_style"]',          'cc-music-style',       500);
    initCharCounter('[name="write_faith"]',          'cc-write-faith',       500);
    initCharCounter('[name="social_strategy"]',      'cc-social-strategy',   500);
    initCharCounter('[name="movie_selections"]',     'cc-movie-selections',  500);
    initCharCounter('[name="gamenight_ideas"]',      'cc-gamenight-ideas',   500);
    initCharCounter('[name="mod_conflict"]',         'cc-mod-conflict',      500);
    initCharCounter('[name="community_ideas"]',      'cc-community-ideas',   600);
    initCharCounter('[name="bible_faith"]',          'cc-bible-faith',       500);
    initCharCounter('[name="bible_topic"]',          'cc-bible-topic',       500);
    initCharCounter('[name="why_join"]',             'cc-why',               600);

    function getFormData() {
        const data = {};
        data.role       = document.getElementById('field-role').value;
        data.name       = document.getElementById('field-name').value.trim();
        data.email      = document.getElementById('field-email').value.trim();
        data.discord    = document.getElementById('field-discord').value.trim();
        data.age        = document.getElementById('field-age').value;
        data.why_join   = document.getElementById('field-why').value.trim();
        data.additional = document.querySelector('[name="additional"]')?.value.trim() || '';

        const activeBlock = document.getElementById('questions-' + selectedRole);
        if (activeBlock) {
            activeBlock.querySelectorAll('.role-field').forEach(field => {
                data[field.name] = field.value.trim();
            });
        }
        return data;
    }

    function validate(data) {
        let valid = true;
        ['field-name','field-email','field-discord','field-age','field-why'].forEach(id => {
            document.getElementById(id)?.classList.remove('error');
        });
        ['err-name','err-email','err-discord','err-age','err-why'].forEach(id => {
            document.getElementById(id)?.classList.remove('visible');
        });

        const showError = (fid, eid) => {
            document.getElementById(fid)?.classList.add('error');
            document.getElementById(eid)?.classList.add('visible');
            valid = false;
        };

        if (!data.name)    showError('field-name',    'err-name');
        if (!data.email || !data.email.includes('@')) showError('field-email', 'err-email');
        if (!data.discord) showError('field-discord', 'err-discord');
        if (!data.age)     showError('field-age',     'err-age');
        if (!data.why_join) showError('field-why',    'err-why');
        return valid;
    }

    async function sendToDiscord(data) {
        const roleLabel = roleLabels[data.role] || data.role;
        const fields = [
            { name: '📋 Role Applied', value: roleLabel,     inline: true },
            { name: '👤 Name',         value: data.name,     inline: true },
            { name: '📧 Email',        value: data.email,    inline: true },
            { name: '💬 Discord',      value: data.discord,  inline: true },
            { name: '🎂 Age Range',    value: data.age,      inline: true },
        ];

        (roleFieldMap[data.role] || []).forEach(({ key, label }) => {
            if (data[key]) fields.push({ name: label, value: data[key].substring(0, 1024), inline: false });
        });

        if (data.why_join)   fields.push({ name: '🙏 Why Join Us',       value: data.why_join.substring(0, 1024),   inline: false });
        if (data.additional) fields.push({ name: '📝 Additional Notes',  value: data.additional.substring(0, 1024), inline: false });

        await fetch(DISCORD_WEBHOOK_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                embeds: [{
                    title: '📬 New Application — ' + roleLabel,
                    color: 0xd4a84b,
                    fields,
                    footer: { text: 'Seventh Day Studios • Application System' },
                    timestamp: new Date().toISOString()
                }]
            })
        });
    }

    async function submitApplication() {
        if (!selectedRole) { alert('Please select a role before submitting.'); return; }

        const data = getFormData();
        if (!validate(data)) {
            document.querySelector('.error-msg.visible')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }

        const btn = document.querySelector('.btn-submit');
        btn.disabled = true;
        btn.textContent = 'Submitting...';

        try {
            await fetch('/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ 'form-name': 'application', ...data }).toString()
            });

            await sendToDiscord(data);

            document.getElementById('application-form').style.display = 'none';
            document.getElementById('success-message').classList.add('visible');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        } catch (err) {
            btn.disabled = false;
            btn.textContent = '✝️ Submit Application';
            alert('Something went wrong. Please try again or contact us on Discord.');
            console.error(err);
        }
    }
</script>

